# Supabase (from Dashboard > Settings > API)
SUPABASE_URL=https://lchxtkiceeyqjksganwr.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (from Dashboard > Settings > Database > Connection string)
# Transaction pooler (port 6543) — used by the app at runtime
SUPABASE_DB_URL=postgresql://postgres.lchxtkiceeyqjksganwr:YOUR_DB_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — used by drizzle-kit migrations only
SUPABASE_DIRECT_URL=postgresql://postgres.lchxtkiceeyqjksganwr:YOUR_DB_PASSWORD@db.lchxtkiceeyqjksganwr.supabase.co:5432/postgres

# JWT — leave empty to use JWKS (recommended for ECC P-256 keys)
# Only set this if your project still uses Legacy HS256 shared secret
SUPABASE_JWT_SECRET=

# App
PORT=3001
FRONTEND_URL=http://localhost:3000

# Microsoft Teams Incoming Webhook (optional — leave empty to disable Teams delivery)
TEAMS_WEBHOOK_URL=
